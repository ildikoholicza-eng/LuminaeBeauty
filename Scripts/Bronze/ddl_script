  );
  GO

-- ── 1e. Orders / Conversions ─────────────────────────────────
DROP TABLE IF EXISTS bronze.orders;
CREATE TABLE bronze.orders (
    order_id                VARCHAR(50),
    order_date              VARCHAR(30),
    order_status            VARCHAR(50),
    customer_id             VARCHAR(50),
    customer_email          VARCHAR(200),
    product_name            VARCHAR(200),
    product_sku             VARCHAR(50),
    quantity                VARCHAR(10),
    unit_price_gbp          VARCHAR(30),
    discount_gbp            VARCHAR(30),
    subtotal_gbp            VARCHAR(30),
    shipping_gbp            VARCHAR(30),
    order_total_gbp         VARCHAR(30),
    attributed_channel      VARCHAR(100),
    attributed_campaign     VARCHAR(200),
    attributed_source       VARCHAR(100),
    session_id              VARCHAR(50),
    payment_method          VARCHAR(50),
    is_new_customer         VARCHAR(10),
    coupon_code             VARCHAR(50),
 );  
GO
