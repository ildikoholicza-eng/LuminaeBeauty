-- ── 1a. Web Analytics ────────────────────────────────────────
DROP TABLE IF EXISTS bronze.web_analytics;
CREATE TABLE bronze.web_analytics (
    session_id          VARCHAR(50),
    session_date        VARCHAR(30),   -- mixed date formats
    channel_grouping    VARCHAR(100),
    source              VARCHAR(100),
    medium              VARCHAR(100),
    campaign            VARCHAR(200),
    landing_page        VARCHAR(500),
    device_category     VARCHAR(50),
    pageviews           VARCHAR(20),
    sessions            VARCHAR(10),
    bounce              VARCHAR(10),
    time_on_site_secs   VARCHAR(20),
    converted           VARCHAR(10),
    order_value_gbp     VARCHAR(30),   -- may contain £ or % typos
    user_id             VARCHAR(50),
    country             VARCHAR(100),
    new_vs_returning    VARCHAR(100),
   );
   GO

-- ── 1b. Meta Ads ─────────────────────────────────────────────
DROP TABLE IF EXISTS bronze.meta_ads;
CREATE TABLE bronze.meta_ads (
    report_date             VARCHAR(30),
    account_id              VARCHAR(50),
    account_name            VARCHAR(200),
    campaign_name           VARCHAR(200),
    campaign_objective      VARCHAR(100),
    adset_name              VARCHAR(200),
    ad_name                 VARCHAR(200),
    placement               VARCHAR(100),
    impressions             VARCHAR(20),
    reach                   VARCHAR(20),
    clicks                  VARCHAR(20),
    spend_gbp               VARCHAR(30),
    ctr_pct                 VARCHAR(30),
    cpc_gbp                 VARCHAR(30),
    conversions             VARCHAR(20),
    conversion_value_gbp    VARCHAR(30),
    roas                    VARCHAR(30),
    frequency               VARCHAR(30),
    currency                VARCHAR(20),
   
);
GO

-- ── 1c. Google PPC ───────────────────────────────────────────
