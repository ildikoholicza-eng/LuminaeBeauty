/*
================================================================
Creating campaign name dimension table 
Primary Key: campaign_key
Description: This view merges Email, Meta, and Google campaign 
             data into a standardized dimension for the Gold layer.
================================================================
*/

IF OBJECT_ID('gold.dim_campaign_name', 'V') IS NOT NULL
    DROP VIEW gold.dim_campaign_name;
GO

CREATE VIEW gold.dim_campaign_name 
AS
WITH combined_campign AS (

    -- EMAIL: Standardized Mapping + Objective Mapping
    SELECT
        send_date AS campaign_date,
        campaign_name AS raw_campaign_name,
        'Email' AS source_platform,
        CASE
            WHEN campaign_name LIKE 'wel%' THEN 'Welcome'
            WHEN campaign_name LIKE '%newsletter%' THEN 'Newsletter'
            WHEN campaign_name LIKE '%flash_sale%' THEN 'Flash Sale'
            WHEN campaign_name LIKE '%abandon%' THEN 'Cart Abandoned'
            WHEN campaign_name LIKE '%win_back%' THEN 'Win Back'
            WHEN campaign_name LIKE '%vip%' THEN 'Loyalty'
            ELSE 'Other'
        END AS standard_campaign_name,
        CASE
            WHEN campaign_name = 'unknown' THEN 'unknown'
            WHEN campaign_name LIKE 'monthly_newsletter%' THEN 'traffic'
            WHEN campaign_name LIKE 'welcome_series%' THEN 'brand_awareness'
            WHEN campaign_name LIKE 'flash_sale%' THEN 'conversions'
            WHEN campaign_name LIKE 'abandoned_cart%' THEN 'conversions'
            WHEN campaign_name LIKE 'vip_early_access%' THEN 'conversions'
            WHEN campaign_name LIKE 'win_back%' THEN 'traffic'
            ELSE 'unknown'
        END AS campaign_objective
    FROM silver.email_analytics
    WHERE send_date > '2000-01-01' 

    UNION ALL

    -- META: Standardized Mapping + Objective Mapping
    SELECT
        report_date AS campaign_date,
        campaign_name AS raw_campaign_name,
        'Meta' AS source_platform,
        CASE 
            WHEN campaign_name LIKE '%nightcream%'  THEN 'Moisturizers'
            WHEN campaign_name LIKE '%cart%'  THEN 'Cart Abandoned'
            WHEN campaign_name LIKE '%dpa%'  THEN 'All Products'
            WHEN campaign_name LIKE '%serum%'  THEN 'Serum'
            WHEN campaign_name LIKE '%awarness%'  THEN 'Awareness'
            WHEN campaign_name LIKE '%spf%'  THEN 'Sign-up'
            ELSE 'Other'
        END AS standard_campaign_name,
        CASE 
            WHEN campaign_name LIKE '%awareness%' THEN 'brand_awareness'
            WHEN campaign_name LIKE '%cart%' THEN 'conversions'
            ELSE 'conversions'
        END AS campaign_objective
    FROM silver.meta_ads
    WHERE report_date > '2000-01-01' 

    UNION ALL

    -- GOOGLE PPC: Standardized Mapping + Objective Mapping
    SELECT 
        event_date AS campaign_date,
        campaign AS raw_campaign_name,
        'Google' AS source_platform,
        CASE 
            WHEN campaign LIKE '%moisturiser%'  THEN 'Moisturizers'
            WHEN campaign LIKE '%cart%'  THEN 'Cart Abandoned'
            WHEN campaign LIKE '%dsa%'  THEN 'All Products'
            WHEN campaign LIKE '%serum%'  THEN 'Serum'
            WHEN campaign LIKE '%skincare%'  THEN 'Skincare'
            WHEN campaign LIKE '%kw%'  THEN 'Keyword Targeting'
            ELSE 'Other'
        END AS standard_campaign_name,
        CASE 
            WHEN campaign = 'unknown' THEN 'unknown'
            WHEN campaign LIKE 'dsa_all_products%' THEN 'conversions'
            WHEN campaign LIKE 'shopping_%' THEN 'conversions'
            WHEN campaign LIKE 'generic_skincare_broad%' THEN 'traffic'
            WHEN campaign LIKE 'brand_kw_exact%' THEN 'brand_awareness'
            WHEN campaign LIKE 'rlsa_cart_abandoners%' THEN 'conversions'
            WHEN campaign LIKE 'competitor_kw_bmm%' THEN 'brand_awareness'
            ELSE 'unknown'
        END AS campaign_objective
    FROM silver.google_ppc
    WHERE event_date > '2000-01-01' 

) 

SELECT
    -- Unique key based on the raw name to ensure one ID per campaign
    DENSE_RANK() OVER (ORDER BY raw_campaign_name) AS campaign_key,
    raw_campaign_name,
    standard_campaign_name,
    source_platform,
    campaign_objective,
    MIN(campaign_date) AS start_date,
    MAX(campaign_date) AS end_date,
    DATEDIFF(day, MIN(campaign_date), MAX(campaign_date)) AS campaign_duration_day
FROM 
    combined_campign
GROUP BY 
    raw_campaign_name, 
    standard_campaign_name,
    source_platform,
    campaign_objective;
GO
/*
===============================================================================
SCRIPT TO CREATE: gold.fact_marketing_performance
Sources: silver.google_ppc, silver.meta_ads, silver.web_analytics
Logic: 
  - Unifies Google, Meta, and Email data into one standard schema.
  - Joins with gold.dim_campaign_name to provide the Surrogate Key.
===============================================================================
*/

IF OBJECT_ID('gold.fact_marketing_performance', 'V') IS NOT NULL
    DROP VIEW gold.fact_marketing_performance;
GO

CREATE VIEW gold.fact_marketing_performance AS
WITH unified_source AS (
    -- 1. Google PPC Data
    SELECT 
        campaign AS raw_campaign_name,
        event_date,
        Network AS channel_source,
        Impressions AS impressions,
        Clicks AS clicks,
        Cost_Gbp AS spend,
        Conv_Value_Gbp AS revenue
    FROM LuminaeBeauty.silver.google_ppc
    WHERE event_date > '1900-01-01'

    UNION ALL

    -- 2. Meta Ads Data
    SELECT 
        campaign_name AS raw_campaign_name,
        report_date AS event_date,
        'Meta' AS channel_source,
        impressions,
        clicks,
        spend_gbp AS spend,
        conversion_value_gbp AS revenue
    FROM LuminaeBeauty.silver.meta_ads
    WHERE report_date > '1900-01-01'

    UNION ALL

    -- 3. Email/Web Analytics Data
    SELECT 
        campaign AS raw_campaign_name,
        session_date AS event_date,
        'Email' AS channel_source,
        0 AS impressions,
        sessions AS clicks, 
        0 AS spend,
        order_value_gbp AS revenue
    FROM LuminaeBeauty.silver.web_analytics
    WHERE channel_grouping = 'email' 
      AND session_date > '1900-01-01'
)

SELECT 
    dim.campaign_key,
    src.event_date,
    src.channel_source,
    DATEDIFF(DAY, CAST(src.event_date AS DATE), GETDATE()) AS campaign_duration,
    src.spend,
    src.impressions,
    src.clicks,
    src.revenue
FROM unified_source src
LEFT JOIN gold.dim_campaign_name dim 
    ON src.raw_campaign_name = dim.raw_campaign_name;
GO

-- Quick Check
SELECT TOP 20 * FROM gold.fact_marketing_performance
ORDER BY event_date DESC;
/* ============================================================
DIMENSION VIEW: gold.dim_sources
Includes: Source, Medium, Channel Group, and Device Type
============================================================ */
IF OBJECT_ID('gold.dim_sources', 'V') IS NOT NULL
    DROP VIEW gold.dim_sources;
GO

CREATE VIEW gold.dim_sources AS
SELECT 
    -- Generating a consistent ID based on the unique combination
    DENSE_RANK() OVER (ORDER BY source, medium, channel_grouping, device_category) AS source_key,
    source AS source_name,
    medium,
    channel_grouping,
    device_category AS device_type
FROM silver.web_analytics
GROUP BY source, medium, channel_grouping, device_category;
GO

/* ============================================================
DIMENSION VIEW: gold.dim_products
Consistent with existing Silver data types
============================================================ */
IF OBJECT_ID('gold.dim_products', 'V') IS NOT NULL
    DROP VIEW gold.dim_products;
GO

CREATE VIEW gold.dim_products AS
SELECT DISTINCT
    DENSE_RANK() OVER (ORDER BY product_sku, product_name) AS product_key,
    product_sku,
    product_name,
    -- Simple category logic for Power BI grouping
    CASE 
        WHEN product_name LIKE '%serum%' THEN 'Serums'
        WHEN product_name LIKE '%moisturiser%' OR product_name LIKE '%cream%' THEN 'Moisturisers'
        WHEN product_name LIKE '%toner%' THEN 'Toners'
        ELSE 'Skincare'
    END AS category
FROM silver.orders
WHERE product_name IS NOT NULL 
  AND product_name <> 'unknown';
GO
/* ============================================================
FACT VIEW: gold.fact_orders
Logic: Filtered for valid transactions and linked to Gold Dimensions
============================================================ */
IF OBJECT_ID('gold.fact_orders', 'V') IS NOT NULL
    DROP VIEW gold.fact_orders;
GO

CREATE VIEW gold.fact_orders AS
SELECT 
    -- Primary Key for the Fact Table
    ROW_NUMBER() OVER (ORDER BY o.order_date, o.order_id_clean) AS order_line_id,
    o.order_id_clean AS order_id,
    o.order_date,
    
    -- Foreign Keys to Gold Dimensions
    dp.product_key,
    dc.campaign_key,
    
    -- Order Attributes
    o.customer_id,
    o.session_id,
    o.payment_method,
    o.order_status,
    o.coupon_code,
    o.attributed_channel,
    o.attributed_source,
    
    -- Numeric Measures
    o.quantity,
    o.unit_price_gbp,
    o.discount_gbp,
    o.subtotal_gbp,
    o.shipping_gbp,
    o.order_total_gbp,
    
    -- Flags
    o.is_refund,
    o.is_valid_transaction,
    o.is_new_customer
FROM silver.orders o
-- Match to Product Dim
LEFT JOIN gold.dim_products dp 
    ON o.product_sku = dp.product_sku 
    AND o.product_name = dp.product_name
-- Match to Campaign Dim
LEFT JOIN gold.dim_campaign_name dc 
    ON o.attributed_campaign = dc.raw_campaign_name

/* --- DATA QUALITY FILTERS --- */
WHERE o.order_date > '1900-01-01'              -- Filter out placeholder dates
  AND o.product_name <> 'unknown'             -- Filter out untracked products
  AND o.order_status NOT IN ('cancelled')     -- Filter out non-sales
  AND o.order_total_gbp > 0;                  -- Filter out zero-value errors
GO
