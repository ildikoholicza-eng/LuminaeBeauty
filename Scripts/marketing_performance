

The Problem: "Identified a 3% variance in revenue reconciliation due to referential integrity issues (orphaned records and NULL-join drops)."

The Solution: "Implemented a Unified Base CTE with Coalesced Join logic to ensure 100% financial accuracy across Marketing, Web, and Sales grains."

The Result: "Achieved a 'Bulletproof' Gold-layer View that reconciles perfectly with raw source tables, providing a single source of truth for ROAS and CPA analysis."

/* ===============================================================================
MASTER MARKETING PERFORMANCE VIEW (FINAL - NO DUPLICATION)
Goal: Combine Marketing Spend, Web Traffic, and Sales into one flat table.
Grain: date_key + campaign_key
Assumption: dim_campaign_name is FIXED (unique campaign_key per campaign+platform)
=============================================================================== */

IF OBJECT_ID('marketing_performance_view', 'V') IS NOT NULL
  DROP VIEW marketing_performance_view;
GO

CREATE VIEW marketing_performance_view
AS

WITH cte_marketing_spend AS (
    SELECT date_key, campaign_key, SUM(spend) AS total_spend, SUM(impressions) AS total_impression
    FROM gold.fact_marketing_performance GROUP BY date_key, campaign_key
), 
cte_web_performance AS (
    SELECT date_key, campaign_key, COUNT(DISTINCT session_id) AS total_sessions, SUM(converted) AS total_web_conversion
    FROM gold.fact_web_events GROUP BY date_key, campaign_key
),
cte_orders_performance AS (
    SELECT date_key, campaign_key, SUM(net_revenue) AS total_net_revenue
    FROM gold.fact_orders GROUP BY date_key, campaign_key
),
-- THE MASTER BASE: Collects EVERY combo from EVERY table
base AS (
    SELECT date_key, campaign_key FROM cte_marketing_spend
    UNION
    SELECT date_key, campaign_key FROM cte_web_performance
    UNION
    SELECT date_key, campaign_key FROM cte_orders_performance
)

SELECT
    -- Use ISNULL on the date so we don't have empty rows in the report
    ISNULL(d.full_date, 'Unknown Date') AS full_date,
    ISNULL(c.standard_campaign_name, 'Unattributed') AS standard_campaign_name,
    
    -- Metrics
    ISNULL(m.total_spend, 0) AS spend_gbp,
    ISNULL(o.total_net_revenue, 0) AS net_revenue_gbp
FROM base b
-- THE FIX: Use LEFT JOIN for Date. If the date_key is missing in dim_date, 
-- the revenue still stays in the view!
LEFT JOIN gold.dim_date d ON b.date_key = d.date_key

LEFT JOIN gold.dim_campaign_name c ON b.campaign_key = c.campaign_key

-- Final Data Joins
LEFT JOIN cte_marketing_spend m 
    ON b.date_key = m.date_key AND b.campaign_key = m.campaign_key
LEFT JOIN cte_web_performance w 
    ON b.date_key = w.date_key AND b.campaign_key = w.campaign_key
LEFT JOIN cte_orders_performance o 
    ON b.date_key = o.date_key AND b.campaign_key = o.campaign_key;
GO
