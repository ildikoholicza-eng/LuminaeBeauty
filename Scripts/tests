SELECT 
*
FROM
silver.meta_ads

--date check 
select * from 
silver.meta_ads
Where try_cast(report_date as date)is null
And report_date is not null;

select * from 
silver.meta_ads
WHERE try_cast(report_date as Date) <'1900-01-01'
or try_cast(report_date as date ) > getdate()



SELECT 
min( try_cast( report_date as date)) as earliest ,
max( try_cast( report_date as date)) as latest
From
silver.meta_ads

--check for empty strings
select 
*
from 
silver.meta_ads
where account_id = ' '

Select distinct account_id 
from silver.meta_ads
Where account_id like 'unknown'

SELECT
DISTINCT placement
from silver.meta_ads

campaign_objective, adset_name, ad_name, placement

SELECT *
FROM silver.meta_ads
WHERE 
    impressions < 0
    OR reach < 0
    OR clicks < 0
    OR spend_gbp < 0
    OR cpc_gbp < 0
    OR conversion_value_gbp < 0;


-- clicks cannot exceed impressions
SELECT *
FROM silver.meta_ads
WHERE clicks > impressions;


