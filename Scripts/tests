*from 
silver.orders


Select *
from 
silver.web_analytics

Select
converted,
order_value_gbp
from silver.web_analytics
where converted = 0 and order_value_gbp > 0


--every session has at least one pageviews
select
*
from silver.web_analytics
where
pageviews < sessions
or bounce> sessions
or converted> sessions;
